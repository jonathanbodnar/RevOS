# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"

# --- LunarPay (single merchant shared across all clinics) ---
# All clinics charge through this one merchant account.
LUNARPAY_BASE_URL="https://app.lunarpay.com"
LUNARPAY_SECRET_KEY="lp_sk_replace_me"
LUNARPAY_PUBLISHABLE_KEY="lp_pk_replace_me"
# Optional: used to verify incoming LunarPay webhooks
LUNARPAY_WEBHOOK_SECRET=""

# Optional: outbound webhook (e.g. Zapier) notified whenever a payment fails
FAILED_PAYMENT_WEBHOOK_URL=""

# --- InBody / LookinBody Web API ---
# API-KEY generated in LookinBody Web → API Setup.
INBODY_API_KEY=""
# LookinBody Web account name (e.g. "revosinbody2"). Used as the `Account`
# header on API calls and to validate incoming webhooks (optional).
INBODY_ACCOUNT=""
# Base URL for the InBody Web API (US region default).
INBODY_API_BASE="https://apiusa.lookinbody.com"
# Optional shared secret. If set, an incoming webhook must carry a header whose
# value equals this (configure it as a security header in LookinBody Web).
INBODY_WEBHOOK_SECRET=""
# NOTE: as of 2026-07-01, the /inbody/* and /user/GetUser data endpoints
# return 401 "You do not have permission to access this service" for this
# account even with a valid API key (only /user/test succeeds) — InBody's API
# is a paid add-on and the account's data-access subscription needs to be
# activated (contact Integration@inbody.com or InBody customer support).

# Public URL used in hosted checkout redirects + invoice links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Fortis Elements JS SDK URL — used by the admin "add card" modal.
# Confirm the exact URL with your LunarPay / Fortis onboarding contact.
NEXT_PUBLIC_FORTIS_ELEMENTS_URL="https://js.fortis.tech/commercejs-v1.0.0.min.js"

