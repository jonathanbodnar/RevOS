# Direct connection — used by Prisma for migrations (port 5432)
DIRECT_URL="postgresql://postgres:[DB_PASSWORD]@db.yhswzrehsigppdaemgwj.supabase.co:5432/postgres"

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
